{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Hangfire": "",
    "Redis": "",
    "MongoDb": ""
  },
  "Elasticsearch": {
    "Uri": ""
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "HealthPlatform.API"
  },
  "Security": {
    "AtRestEncryption": {
      "KeyBase64": ""
    },
    "Tls": {
      "EnforceOutsideDevelopment": true
    }
  },
  "Jwt": {
    "Issuer": "HealthPlatform",
    "Audience": "HealthPlatform",
    "SigningKey": "CHANGE_ME__AT_LEAST_32_BYTES_LONG________________________________________________________________",
    "AccessTokenMinutes": 60,
    "MfaChallengeMinutes": 5
  },
  "DeviceLogin": {
    "ChallengeTtlMinutes": 10,
    "LogOneTimeCodeInDevelopment": false
  },
  "Database": {
    "ApplyMigrations": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
